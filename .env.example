HUA_TFSU_WHISPER_MODEL=small
HUA_TFSU_WHISPER_DEVICE=cpu
HUA_TFSU_WHISPER_COMPUTE_TYPE=int8
HUA_TFSU_ASR_PROVIDER=faster_whisper
HUA_TFSU_CHUNK_SECONDS=2.4
HUA_TFSU_MIN_AUDIO_SECONDS=0.8

# Required for real translation. Any OpenAI-compatible chat/completions endpoint can be used.
HUA_TFSU_OPENAI_API_KEY=
HUA_TFSU_OPENAI_BASE_URL=https://api.openai.com/v1
HUA_TFSU_OPENAI_TRANSLATION_MODEL=gpt-4o-mini
